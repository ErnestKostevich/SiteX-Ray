# Copy this to .dev.vars and paste your keys.
# .dev.vars is gitignored — never commit real keys.
# Used by `wrangler pages dev` for local development only.
# Production keys go in Cloudflare Pages → Settings → Environment variables.

# Email (Cloudflare Email Service)
# Pages may not show Email binding — use CLOUDFLARE_API_TOKEN with Email Sending permission.
# Also onboard sitexray.xyz in Email Service → Email Sending.
FROM_EMAIL=SiteX-Ray <reports@sitexray.xyz>
REPLY_TO_EMAIL=support@sitexray.xyz
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=6609012adc88f397f50eba13ea2c242f

# Claude — paid $39 tier upgrade (OPTIONAL — leave empty to use free Cloudflare AI for paid too)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Cloudflare AI model override (OPTIONAL — defaults to llama-3.1-8b-instruct)
CF_AI_MODEL=

# USDT payments are verified on-chain — no payment processor keys needed.
# Optional: legacy NOWPayments (deprecated, not used by landing page)
# NOWPAYMENTS_API_KEY=
# NOWPAYMENTS_IPN_SECRET=

# Cloudflare Turnstile (optional — leave blank to skip bot check locally)
TURNSTILE_SECRET=